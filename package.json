{
  "name": "rubik-solver",
  "version": "1.0.0",
  "description": "Browser-based Rubik's cube face detector (OpenCV.js, no build step)",
  "scripts": {
    "serve": "python3 server.py",
    "check": "node scripts/check.mjs",
    "watch": "node scripts/watch.mjs",
    "test": "node --test tests/unit.test.mjs tests/detect.test.mjs",
    "test:browser": "node --test tests/harness.test.mjs",
    "test:all": "node --test tests/unit.test.mjs tests/detect.test.mjs tests/harness.test.mjs",
    "detect": "node test/detect.mjs sample.jpg",
    "harness": "node test/harness.mjs tmp/shot.png sample.jpg",
    "full": "node test/full.mjs sample.jpg",
    "alt": "node test/altcheck.mjs sample.jpg",
    "warp": "node test/faceswarp.mjs sample.jpg"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "jpeg-js": "^0.4.4",
    "onnxruntime-node": "^1.26.0",
    "puppeteer": "^25.1.0"
  }
}
